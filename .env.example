# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SerpApi (Google Flights) - usado por el backend para refrescar estatus de vuelo
SERPAPI_API_KEY=your-serpapi-key

# WhatsApp Cloud API - usado por /api/whatsapp/cobranza
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-cloud-api-access-token
WHATSAPP_TEMPLATE_NAME=cobro_saldo_pendiente
WHATSAPP_TEMPLATE_LANG=es_MX
